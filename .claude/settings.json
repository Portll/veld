{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__veld-memory"
    ]
  },
  "mcpServers": {
    "veld-memory": {
      "command": "bun",
      "args": ["run", "mcp-server/index.ts"],
      "env": {
        "VELD_API_URL": "http://127.0.0.1:3030",
        "VELD_USER_ID": "claude-code",
        "VELD_STREAM": "true",
        "VELD_PROACTIVE": "true"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run hooks/memory-hook.ts SessionStart",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run hooks/memory-hook.ts UserPromptSubmit",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run hooks/memory-hook.ts PreToolUse",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run hooks/memory-hook.ts PostToolUse",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run hooks/memory-hook.ts SubagentStop",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run hooks/memory-hook.ts Stop",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
