# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram user ID (for owner-only commands)
# Send /id to @userinfobot to get yours
OWNER_ID=your-telegram-user-id

# Optional: PIN for sensitive commands (shutdown, etc.)
SECURITY_PIN=1234

# Veld (optional - for AI responses)
VELD_API_URL=http://127.0.0.1:3030
VELD_API_KEY=sk-veld-dev-local-testing-key

# Debug mode
DEBUG=false
