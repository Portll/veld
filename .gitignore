coverage/
.coverage
*.lcov
htmlcov/

# Temp/test directories
.venv/
test_*/
release-test/
temp_*/

# Credentials (never commit)
.mcpregistry_*
*.token

# Windows artifacts
nul
.vercel

# Build number (auto-incremented per machine, see build.rs)
