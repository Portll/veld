# Claude settings
.claude/

# Internal documentation (keep local only)
COGNITIVE_ARCHITECTURE.md
*_ARCHITECTURE.md
literature/
literature/

# Paper (not for public release)
paper/

# Local-only legacy collateral
/veld-internal/

# ONNX Runtime binaries (downloaded per-platform during CI wheel builds)
python/veld/lib/*.dll
python/veld/lib/*.so
python/veld/lib/*.dylib
!python/veld/lib/__init__.py

# Model files (downloaded during CI wheel builds)
python/veld/models/minilm-l6/*.onnx
python/veld/models/minilm-l6/*.json
python/veld/models/bert-tiny-ner/*.onnx
python/veld/models/bert-tiny-ner/*.json
