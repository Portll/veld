# Veld - Environment Configuration Example
# Copy this to .env and fill in your values

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================

# Production: Set your API keys (comma-separated for multiple)
# VELD_API_KEYS=sk-your-secure-key-1,sk-your-secure-key-2

# Development: Set a dev key (only if VELD_API_KEYS not set)
VELD_DEV_API_KEY=sk-veld-dev-change-me

# Client API Key: Must match one of the server's accepted keys
# Used by Python client, MCP server, and REST API calls
VELD_API_KEY=sk-veld-dev-change-me

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Environment: "production" or "development" (default: development)
# VELD_ENV=production

# Production-required security settings
# VELD_API_KEYS=sk-prod-key-1,sk-prod-key-2
# VELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Server bind address (default: 127.0.0.1)
# Use 0.0.0.0 for Docker or network-accessible deployments
# VELD_HOST=0.0.0.0

# Server port (default: 3030)
VELD_PORT=3030

# Storage directory (default: platform data dir, e.g. ~/.local/share/shodh-memory/)
# VELD_MEMORY_PATH=/custom/path

# Rate limiting
# Production default is enabled; setting 0 disables it and will warn at startup.
# VELD_RATE_LIMIT=4000
# VELD_RATE_BURST=8000
# VELD_MAX_CONCURRENT=200

# =============================================================================
# INTEGRATIONS (Optional)
# =============================================================================

# Linear Integration
# LINEAR_API_URL=https://api.linear.app/graphql
# LINEAR_WEBHOOK_SECRET=your-linear-webhook-signing-secret

# GitHub Integration
# GITHUB_API_URL=https://api.github.com
# GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# External LLM credentials
# OPENAI_API_KEY=your-openai-api-key

# =============================================================================
# CORS (Optional in development, required for browser access in production)
# =============================================================================

# VELD_CORS_ORIGINS=https://your-frontend.com,https://another-allowed-origin.com
# VELD_CORS_CREDENTIALS=false
# Production without VELD_CORS_ORIGINS rejects all cross-origin browser requests.

# =============================================================================
# LOGGING
# =============================================================================

RUST_LOG=info

# Legacy SHODH_* aliases are still accepted for compatibility.
