{
  "name": "@veld/memory-mcp",
  "version": "0.7.12",
  "mcpName": "io.github.Portll/veld",
  "description": "Persistent cognitive memory for AI agents — semantic search, knowledge graph, Hebbian learning. MCP server for Claude, Cursor, and Codex.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "veld-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "bun run index.ts",
    "build": "bun build index.ts --outdir dist --target node",
    "compile": "bun build index.ts --compile --outfile dist/veld-mcp",
    "compile:windows-x64": "bun build index.ts --compile --target=bun-windows-x64 --outfile dist/veld-mcp-windows-x64.exe",
    "compile:linux-x64": "bun build index.ts --compile --target=bun-linux-x64 --outfile dist/veld-mcp-linux-x64",
    "compile:linux-arm64": "bun build index.ts --compile --target=bun-linux-arm64 --outfile dist/veld-mcp-linux-arm64",
    "compile:darwin-x64": "bun build index.ts --compile --target=bun-darwin-x64 --outfile dist/veld-mcp-darwin-x64",
    "compile:darwin-arm64": "bun build index.ts --compile --target=bun-darwin-arm64 --outfile dist/veld-mcp-darwin-arm64",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node scripts/postinstall.cjs",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "dependencies": {},
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "@vitest/coverage-v8": "^2.1.9",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "ai",
    "llm",
    "persistent-memory",
    "semantic-search",
    "veld"
  ],
  "author": "Veld Team <john@portll.net>",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Portll/veld.git"
  },
  "homepage": "https://github.com/Portll/veld#readme",
  "bugs": {
    "url": "https://github.com/Portll/veld/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
